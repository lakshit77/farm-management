# Copy to .env and fill in real values. Do not commit .env.

# Database (Supabase, RDS, or local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# Wellington API (used for schedule/entries; set for n8n integration)
WELLINGTON_API_BASE_URL=https://sglapi.wellingtoninternational.com
WELLINGTON_CUSTOMER_ID=
WELLINGTON_FARM_NAME=
WELLINGTON_USERNAME=
WELLINGTON_PASSWORD=

# API key for n8n/external callers (Bearer token). If set, all routes except /api/v1/hello require Authorization: Bearer <this value>.
API_SECRET_KEY=

# CORS: comma-separated allowed origins for the frontend.
# Required when frontend is on a different domain (e.g. Vercel HTTPS deployment).
# Example: https://your-app.vercel.app,https://yourdomain.com
CORS_ORIGINS=

# Optional
LOG_LEVEL=INFO
LOG_DIR=logs

# Venue timezone for schedule times (Wellington FL = America/New_York).
# API returns times in venue local; Flow 3 converts to UTC for free-time calculation.
# VENUE_TIMEZONE=America/New_York

# ── Stream Chat ────────────────────────────────────────────────────────────────
# Get these from your Stream dashboard at https://getstream.io
STREAM_API_KEY=
STREAM_API_SECRET=

# Bot user IDs (these are the Stream user IDs for each bot; defaults shown)
STREAM_ALLTEAM_BOT_ID=all-team-bot
STREAM_ADMIN_BOT_ID=admin-bot
STREAM_PERSONAL_BOT_ID=personal-bot

# n8n webhook URLs — one per bot context (set these to your n8n workflow webhook URLs)
N8N_ALLTEAM_WEBHOOK_URL=
N8N_ADMIN_WEBHOOK_URL=
N8N_PERSONAL_WEBHOOK_URL=
